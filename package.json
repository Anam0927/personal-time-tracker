{
  "name": "time-tracker",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "cli": "bun run index.ts",
    "check": "bunx tsc --noEmit",
    "test": "bun test --isolate",
    "build": "bun build ./index.ts --outfile ./tt --bytecode --format=esm --compile",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "db:make": "bunx --bun kysely migrate:make",
    "db:migrate": "bunx --bun kysely migrate:latest",
    "db:rollback": "bunx --bun kysely migrate:down",
    "db:codegen": "DATABASE_URL=$(bun run scripts/get-db-path.ts) bunx --bun kysely-codegen",
    "db:setup": "bun run db:migrate && bun run db:codegen"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.8",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.46.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "kysely": "^0.28.16",
    "kysely-bun-sqlite": "^0.4.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1",
    "xdg-basedir": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^5"
  }
}
