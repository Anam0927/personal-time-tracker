{
  "dialect": "kysely-bun-sqlite",
  "outFile": "./src/db/types.ts",
  "url": "env(DATABASE_URL)",
  "overrides": {
    "columns": {
      "clients.id": "Generated<number>",
      "projects.id": "Generated<number>",
      "sessions.id": "Generated<number>",
      "sessions.status": "'active' | 'paused' | 'completed'",
      "tags.id": "Generated<number>",
      "pause_events.id": "Generated<number>",
      "notification_events.id": "Generated<number>",
      "app_state.key": "string"
    }
  }
}
