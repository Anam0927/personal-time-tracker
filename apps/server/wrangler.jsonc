{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "time-tracker-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "workers_dev": true,
  "observability": {
    "enabled": true,
  },
  "upload_source_maps": true,
  "vars": {
    "WORKERS_URL": "tt-server.anaam.io",
  },
}
